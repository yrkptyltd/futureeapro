<section class="panel client-face-picker">
  <h3>Card Shape</h3>
  <div class="option-chip-grid face-shape-grid">
    <button type="button" class="option-chip active" data-face-style-choice="square">Square</button>
    <button type="button" class="option-chip" data-face-style-choice="rounded">Rounded</button>
    <button type="button" class="option-chip" data-face-style-choice="pill">Pill</button>
    <button type="button" class="option-chip" data-face-style-choice="super-pill">Super Pill</button>
    <button type="button" class="option-chip" data-face-style-choice="capsule">Capsule</button>
    <button type="button" class="option-chip" data-face-style-choice="frame">Neon Frame</button>
  </div>
</section>
