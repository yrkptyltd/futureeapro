<%- include('partials/top', { title: title }) %>
<% const activeSection = currentSection || 'overview'; %>

<section class="mentor-layout drawer-layout">
  <button
    type="button"
    class="dashboard-drawer-toggle dashboard-drawer-toggle-fab"
    data-dashboard-drawer-toggle
    aria-expanded="false"
    aria-controls="mentor-dashboard-drawer"
    aria-label="Open sidebar menu"
  >
    <span aria-hidden="true">☰</span>
  </button>

  <button
    type="button"
    class="dashboard-drawer-backdrop"
    data-dashboard-drawer-backdrop
    aria-label="Close sidebar menu"
  ></button>

  <aside class="mentor-sidebar" id="mentor-dashboard-drawer" data-dashboard-drawer>
    <div class="sidebar-brand">
      <span class="sidebar-logo">F</span>
      <div>
        <p class="sidebar-brand-title">Future EA Pro</p>
        <p class="sidebar-brand-subtitle">Mentor Portal</p>
      </div>
    </div>

    <a href="/mentor/dashboard?section=my-profile#my-profile" class="sidebar-profile">
      <span class="sidebar-avatar"><%= (mentor.name || 'M').charAt(0).toUpperCase() %></span>
      <span>
        <strong><%= mentor.name %></strong>
        <small>Mentor #<%= mentor.mentorPortalId %></small>
      </span>
      <span class="sidebar-chevron">></span>
    </a>

    <div class="sidebar-group">
      <h2>Core</h2>
      <a href="/mentor/dashboard?section=overview#overview" class="sidebar-link <%= activeSection === 'overview' ? 'active' : '' %>">
        <span class="nav-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24">
            <rect x="3.5" y="3.5" width="7" height="7" rx="1.1"></rect>
            <rect x="13.5" y="3.5" width="7" height="7" rx="1.1"></rect>
            <rect x="3.5" y="13.5" width="7" height="7" rx="1.1"></rect>
            <rect x="13.5" y="13.5" width="7" height="7" rx="1.1"></rect>
          </svg>
        </span>
        Dashboard
      </a>
      <a href="/mentor/dashboard?section=track-business#track-business" class="sidebar-link <%= activeSection === 'track-business' ? 'active' : '' %>">
        <span class="nav-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24">
            <path d="M3.5 17.5L9 12l3.2 3.2L20.5 7"></path>
            <path d="M14.5 7h6v6"></path>
          </svg>
        </span>
        Track Business
      </a>
      <a href="/mentor/dashboard?section=manage-eas#manage-eas" class="sidebar-link <%= activeSection === 'manage-eas' ? 'active' : '' %>">
        <span class="nav-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24">
            <rect x="4.5" y="7.5" width="15" height="11" rx="2.2"></rect>
            <path d="M12 3.5v4"></path>
            <circle cx="9.2" cy="12.2" r="1"></circle>
            <circle cx="14.8" cy="12.2" r="1"></circle>
            <path d="M9 15.3h6"></path>
          </svg>
        </span>
        Manage EAs
      </a>
      <a href="/mentor/dashboard?section=forex-events#forex-events" class="sidebar-link <%= activeSection === 'forex-events' ? 'active' : '' %>">
        <span class="nav-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24">
            <path d="M4 5.5h16"></path>
            <path d="M4 12h16"></path>
            <path d="M4 18.5h16"></path>
            <circle cx="8" cy="5.5" r="1.2"></circle>
            <circle cx="14" cy="12" r="1.2"></circle>
            <circle cx="10" cy="18.5" r="1.2"></circle>
          </svg>
        </span>
        Forex Events
      </a>
    </div>

    <div class="sidebar-group">
      <h2>Profile</h2>
      <a href="/mentor/dashboard?section=my-profile#my-profile" class="sidebar-link <%= activeSection === 'my-profile' ? 'active' : '' %>">
        <span class="nav-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24">
            <circle cx="12" cy="8" r="3.2"></circle>
            <path d="M5 19c1.6-3 4-4.5 7-4.5s5.4 1.5 7 4.5"></path>
          </svg>
        </span>
        My Profile
      </a>
    </div>

    <div class="sidebar-bottom-actions">
      <form action="/logout" method="POST" class="inline-form">
        <button type="submit" class="button secondary sidebar-logout-btn">Sign Out</button>
      </form>
    </div>
  </aside>

  <div class="mentor-main">
    <section class="dashboard-overview <%= activeSection === 'overview' ? '' : 'section-hidden' %>" id="overview">
      <div class="overview-top-row">
        <p class="status-pill ok"><span>●</span>All systems running smoothly</p>
        <p class="status-pill"><span>📅</span>Today — <%= dashboardDateLabel %></p>
      </div>

      <article class="panel welcome-banner">
        <div class="welcome-icon" aria-hidden="true">🛡️</div>
        <div>
          <h2>Welcome back</h2>
          <p class="welcome-sub">You have <strong><%= dashboardTotals.activeSubscribers %> active subscribers</strong> running on your account.</p>
          <p class="mentor-id-pill">Mentor ID: <strong><%= mentor.mentorPortalId %></strong></p>
        </div>
      </article>

      <div class="kpi-grid">
        <article class="kpi-card red">
          <h3>Total Keys</h3>
          <p class="kpi-value"><%= mentor.licenseKeyLimit %></p>
          <p>Your current key allowance</p>
        </article>
        <article class="kpi-card green">
          <h3>Generated Keys</h3>
          <p class="kpi-value"><%= dashboardTotals.totalGenerated %></p>
          <p>All time generated</p>
        </article>
        <article class="kpi-card blue">
          <h3>Active Subscribers</h3>
          <p class="kpi-value"><%= dashboardTotals.activeSubscribers %></p>
          <p>Paid and currently active</p>
        </article>
        <article class="kpi-card orange">
          <h3>Total EAs</h3>
          <p class="kpi-value"><%= robots.length %></p>
          <p>Robots registered</p>
        </article>
      </div>
    </section>

    <section class="panel-grid single <%= activeSection === 'track-business' ? '' : 'section-hidden' %>" id="track-business">
      <article class="panel">
        <h2>Track My Business</h2>
        <p class="hint">Set your price and monthly target, then monitor revenue progress.</p>

        <form action="/mentor/business-settings" method="POST" class="stack-form">
          <div class="row-fields">
            <label>
              Robot Price (per key)
              <input
                type="number"
                name="robotPricePerKey"
                min="0"
                step="0.01"
                value="<%= businessMetrics.robotPricePerKey %>"
                required
              />
            </label>

            <label>
              Monthly Target (keys)
              <input
                type="number"
                name="monthlyKeyTarget"
                min="0"
                step="1"
                value="<%= businessMetrics.monthlyKeyTarget %>"
                required
              />
            </label>

            <label>
              Currency
              <select name="businessCurrency">
                <option value="ZAR" <%= businessMetrics.businessCurrency === 'ZAR' ? 'selected' : '' %>>ZAR (R)</option>
                <option value="USD" <%= businessMetrics.businessCurrency === 'USD' ? 'selected' : '' %>>USD ($)</option>
              </select>
            </label>
          </div>

          <button type="submit" class="button">Save Business Targets</button>
        </form>

        <div class="business-grid">
          <article class="business-card">
            <h3>Keys Sold (<%= businessMetrics.monthLabel %>)</h3>
            <p class="business-value"><%= businessMetrics.keysSoldThisMonth %></p>
          </article>

          <article class="business-card">
            <h3>Monthly Revenue</h3>
            <p class="business-value">R<%= businessMetrics.monthlyRevenue.toFixed(2) %></p>
            <p class="hint">Subscription plans (ZAR)</p>
          </article>

          <article class="business-card">
            <h3>All-Time Revenue (Estimated)</h3>
            <p class="business-value">R<%= businessMetrics.estimatedTotalRevenue.toFixed(2) %></p>
          </article>

          <article class="business-card">
            <h3>Projected Revenue (Your Price)</h3>
            <p class="business-value"><%= businessMetrics.currencySymbol %><%= businessMetrics.projectedRevenueByMentorPrice.toFixed(2) %></p>
          </article>

          <article class="business-card">
            <h3>Goal Revenue (At Target)</h3>
            <p class="business-value"><%= businessMetrics.currencySymbol %><%= businessMetrics.goalRevenueAtTarget.toFixed(2) %></p>
          </article>

          <article class="business-card">
            <h3>Target Remaining</h3>
            <p class="business-value"><%= businessMetrics.targetRemaining %></p>
          </article>
        </div>

        <div class="progress-wrap">
          <div class="progress-track">
            <div class="progress-fill" style="width: <%= businessMetrics.targetProgressPercent %>%"></div>
          </div>
          <p class="hint">
            Target progress: <strong><%= businessMetrics.targetProgressPercent %>%</strong>
            <% if (businessMetrics.targetReached) { %>
            (Target reached)
            <% } %>
          </p>
        </div>
      </article>
    </section>

    <section class="panel-grid single <%= activeSection === 'manage-eas' ? '' : 'section-hidden' %>" id="manage-eas">
      <article class="panel">
        <h2>Manage EAs</h2>
        <p class="hint">Create new robots and generate client license keys from this section.</p>

        <% if (!mentor.subscriptionActive) { %>
        <p class="warning">Your subscription is currently inactive. Ask superhost to reactivate access.</p>
        <% } %>

        <h3>New EA</h3>
        <p class="hint">Add a new Expert Advisor to licence</p>

        <form action="/mentor/robots" method="POST" class="stack-form">
          <label>
            EA NAME
            <input type="text" name="name" placeholder="ALGO NOVA EA v6" required />
          </label>

          <label class="confirm-check">
            <input type="checkbox" name="confirmAdmin" value="yes" required />
            <span>I confirm that I am an admin</span>
          </label>

          <input type="hidden" name="description" value="" />
          <input type="hidden" name="category" value="Expert Advisor" />
          <input type="hidden" name="imageUrl" value="" />
          <input type="hidden" name="allowedSymbols" value="<%= defaultSymbolsText %>" />
          <input type="hidden" name="version" value="v1.0.0" />
          <input type="hidden" name="status" value="active" />
          <input type="hidden" name="uptimeHours" value="0" />
          <input type="hidden" name="tasksCompleted" value="0" />
          <input type="hidden" name="successRate" value="0" />
          <input type="hidden" name="lastSync" value="Not provided" />

          <div class="cta-row">
            <button type="submit" class="button">Add EA</button>
            <a href="/mentor/dashboard?section=manage-eas#manage-eas" class="button secondary">Cancel</a>
          </div>
        </form>

        <hr class="subtle-divider" />

        <h3>Generate License Key</h3>
        <p class="hint">Keys are generated, reserved to the client email, and emailed automatically.</p>

        <form action="/mentor/license-keys/generate" method="POST" class="stack-form">
          <label>
            Client Email
            <input type="email" name="clientEmail" placeholder="client@example.com" required />
          </label>

          <label>
            Expert Advisor (Robot)
            <select name="robotId" required>
              <option value="">Select robot</option>
              <% robots.forEach((robot) => { %>
              <option value="<%= robot.id %>"><%= robot.name %></option>
              <% }) %>
            </select>
          </label>

          <label>
            License Key Duration
            <select name="durationCode" required>
              <option value="">Select duration</option>
              <% licenseDurationOptions.forEach((item) => { %>
              <option value="<%= item.code %>"><%= item.label %></option>
              <% }) %>
            </select>
          </label>
          <button type="submit" class="button" <%= robots.length ? '' : 'disabled' %>>
            Generate & Email Key
          </button>
        </form>

        <% if (!licenseKeys.length) { %>
        <p class="hint">No client keys generated yet.</p>
        <% } else { %>
        <ul class="list key-list">
          <% licenseKeys.forEach((item) => { %>
          <li class="key-entry">
            <div class="key-copy-row">
              <input type="text" class="key-copy-input" value="<%= item.key %>" readonly />
              <button type="button" class="button mini secondary copy-key-btn" data-copy-value="<%= item.key %>">Copy</button>
            </div>
            <p class="hint">
              Client: <strong><%= item.reservedClientEmail || 'N/A' %></strong> |
              EA: <strong><%= item.robotName || 'Not set' %></strong> |
              Duration: <strong><%= item.durationLabel || 'Not set' %></strong>
            </p>
            <% if (item.redeemedAt || item.status === 'redeemed') { %>
            <span class="pill ok">redeemed</span>
            <span class="hint">by <%= item.redeemedByClientEmail || 'client' %></span>
            <% } else if (item.reservedClientEmail) { %>
            <span class="pill">reserved</span>
            <span class="hint">for <%= item.reservedClientEmail %></span>
            <% } else { %>
            <span class="pill">available</span>
            <% } %>
          </li>
          <% }) %>
        </ul>
        <% } %>

        <hr class="subtle-divider" />

        <h3>Your Expert Advisors</h3>
        <p class="hint">All EAs registered under your account</p>

        <% if (!robots.length) { %>
        <p class="hint">No robots created yet.</p>
        <% } else { %>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>EA</th>
                <th>USERS</th>
                <th>ACTIVE</th>
                <th>CREATED</th>
                <th>ACTIONS</th>
              </tr>
            </thead>
            <tbody>
              <% robots.forEach((robot) => { %>
              <tr>
                <td>
                  <strong><%= robot.name %></strong>
                </td>
                <td><%= robot.totalUsers || 0 %></td>
                <td><%= robot.activeUsers || 0 %></td>
                <td><%= robot.createdLabel || '-' %></td>
                <td>
                  <form action="/mentor/robots/<%= robot.id %>/test" method="POST" class="inline-form">
                    <button type="submit" class="button mini secondary">Test</button>
                  </form>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
        <% } %>
      </article>
    </section>

    <section class="panel-grid single <%= activeSection === 'forex-events' ? '' : 'section-hidden' %>" id="forex-events">
      <article class="panel">
        <h2>Forex Events</h2>
        <p class="hint">Showing upcoming events from <strong><%= forexEvents.fromLabel %></strong> to <strong><%= forexEvents.toLabel %></strong>. Past history is excluded automatically.</p>

        <% if (!forexEvents.items.length) { %>
        <p class="hint">No upcoming high-priority forex events are available right now.</p>
        <% } else { %>
        <div class="events-list">
          <% forexEvents.items.forEach((event) => { %>
          <article class="event-row">
            <div>
              <p class="event-title"><%= event.title %></p>
              <p class="hint"><%= event.dayLabel %> • <%= event.timeLabel %> (SAST)</p>
            </div>
            <div class="event-meta">
              <span class="pill"><%= event.country %></span>
              <span class="pill <%= String(event.impact || '').toLowerCase() === 'high' ? 'off' : 'ok' %>"><%= event.impact %></span>
            </div>
          </article>
          <% }) %>
        </div>
        <% } %>
      </article>
    </section>

    <section class="panel-grid single <%= activeSection === 'my-profile' ? '' : 'section-hidden' %>" id="my-profile">
      <article class="panel">
        <h2>My Profile (Portal Only)</h2>
        <p class="hint">These details are shown on the portal and never in the client app.</p>

        <form action="/mentor/profile" method="POST" class="stack-form">
          <div class="row-fields">
            <label>
              Display Name
              <input type="text" name="name" value="<%= mentor.name %>" required />
            </label>

            <label>
              Profile Headline
              <input type="text" name="profileHeadline" value="<%= mentor.profileHeadline || '' %>" placeholder="Lead Robotics Mentor" />
            </label>
          </div>

          <label>
            Bio
            <textarea name="profileBio" rows="3" placeholder="Short mentor background"><%= mentor.profileBio || '' %></textarea>
          </label>

          <div class="row-fields">
            <label>
              Phone
              <input type="text" name="profilePhone" value="<%= mentor.profilePhone || '' %>" />
            </label>

            <label>
              Profile Image URL
              <input type="url" name="profileImageUrl" value="<%= mentor.profileImageUrl || '' %>" placeholder="https://..." />
            </label>
          </div>

          <button type="submit" class="button">Save My Profile</button>
        </form>

        <% if (mentor.profileImageUrl) { %>
        <div class="profile-preview">
          <img src="<%= mentor.profileImageUrl %>" alt="Mentor profile image" class="robot-thumb" />
          <p class="hint">Portal preview only.</p>
        </div>
        <% } %>
      </article>
    </section>
  </div>
</section>

<%- include('partials/bottom') %>
