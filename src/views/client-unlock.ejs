<%- include('partials/top', { title: title }) %>

<section class="dashboard-head">
  <h1>Unlock Robot Access</h1>
  <p>
    Plan: <strong><%= plan ? plan.label : flow.planCode %></strong>
    | Amount: <strong>R<%= plan ? plan.amountZar : '-' %></strong>
  </p>
  <p>Client Email: <strong><%= flow.clientEmail %></strong></p>
</section>

<section class="panel-grid">
  <article class="panel">
    <h2>Enter Unique License Key</h2>
    <p class="hint">
      Enter the unique license key generated by your mentor to unlock the robot interface.
    </p>

    <form action="/client/unlock" method="POST" class="stack-form">
      <label>
        License Key
        <input type="text" name="licenseKey" placeholder="e.g. 100" required />
      </label>

      <button type="submit" class="button">Unlock Robot</button>
    </form>
  </article>

  <article class="panel client-face-card">
    <h2>Robot Preview</h2>
    <% if (featuredRobot && featuredRobot.imageUrl) { %>
    <img
      src="<%= featuredRobot.imageUrl %>"
      alt="<%= featuredRobot.name %> preview"
      class="robot-preview-lg robot-preview-feature"
    />
    <p><strong><%= featuredRobot.name %></strong></p>
    <% } else if (featuredRobot) { %>
    <p><strong><%= featuredRobot.name %></strong></p>
    <p class="hint">Robot image not uploaded yet.</p>
    <% } else { %>
    <p class="hint">No robot profile is available yet for this mentor.</p>
    <% } %>
  </article>
</section>

<%- include('partials/bottom') %>
