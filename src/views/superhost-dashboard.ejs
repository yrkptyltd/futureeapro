<%- include('partials/top', { title: title }) %>

<% const lab = superhostLab || {}; %>
<% const labAccount = lab.account || currentUser; %>
<% const labTotals = lab.dashboardTotals || { totalKeys: 0, totalGenerated: 0, activeSubscribers: 0 }; %>
<% const labBusiness = lab.businessMetrics || { businessCurrency: 'ZAR', currencySymbol: 'R', robotPricePerKey: 0, monthlyKeyTarget: 0, keysSoldThisMonth: 0, monthlyRevenue: 0, estimatedTotalRevenue: 0, projectedRevenueByMentorPrice: 0, goalRevenueAtTarget: 0, targetRemaining: 0, targetProgressPercent: 0, targetReached: false, monthLabel: 'This Month' }; %>
<% const labRobots = lab.robots || []; %>
<% const labLicenseKeys = lab.licenseKeys || []; %>
<% const labActiveKeysUsed = lab.activeKeysUsed || 0; %>
<% const activeSection = currentSection || 'overview'; %>

<section class="dashboard-head dashboard-head-drawer">
  <div>
    <h1>Superhost Dashboard</h1>
    <p>
      Signed in as <strong><%= currentUser.email %></strong>. Superhost controls stay available, and this dashboard now includes a mentor-style test lab.
    </p>
  </div>
  <button
    type="button"
    class="dashboard-drawer-toggle"
    data-dashboard-drawer-toggle
    aria-expanded="false"
    aria-controls="superhost-dashboard-drawer"
    aria-label="Open sidebar menu"
  >
    <span aria-hidden="true">☰</span>
    Menu
  </button>
</section>

<section class="mentor-layout drawer-layout">
  <button
    type="button"
    class="dashboard-drawer-backdrop"
    data-dashboard-drawer-backdrop
    aria-label="Close sidebar menu"
  ></button>
  <aside class="mentor-sidebar" id="superhost-dashboard-drawer" data-dashboard-drawer>
    <div class="sidebar-brand">
      <span class="sidebar-logo">F</span>
      <div>
        <p class="sidebar-brand-title">Future EA Pro</p>
        <p class="sidebar-brand-subtitle">Superhost Portal</p>
      </div>
    </div>

    <a href="/superhost/dashboard?section=my-profile#my-profile" class="sidebar-profile">
      <span class="sidebar-avatar"><%= (labAccount.name || 'S').charAt(0).toUpperCase() %></span>
      <span>
        <strong><%= labAccount.name %></strong>
        <small>Superhost</small>
      </span>
      <span class="sidebar-chevron">></span>
    </a>

    <div class="sidebar-group">
      <h2>Core</h2>
      <a href="/superhost/dashboard?section=overview#overview" class="sidebar-link <%= activeSection === 'overview' ? 'active' : '' %>">
        <span class="nav-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24">
            <rect x="3.5" y="3.5" width="7" height="7" rx="1.1"></rect>
            <rect x="13.5" y="3.5" width="7" height="7" rx="1.1"></rect>
            <rect x="3.5" y="13.5" width="7" height="7" rx="1.1"></rect>
            <rect x="13.5" y="13.5" width="7" height="7" rx="1.1"></rect>
          </svg>
        </span>
        Dashboard
      </a>
      <a href="/superhost/dashboard?section=users#users" class="sidebar-link <%= activeSection === 'users' ? 'active' : '' %>">
        <span class="nav-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24">
            <circle cx="8" cy="9" r="2.6"></circle>
            <circle cx="16.2" cy="9.8" r="2.1"></circle>
            <path d="M3.8 19c1.2-2.8 3.2-4.2 6.1-4.2 2.8 0 4.8 1.4 6 4.2"></path>
            <path d="M14 19c.8-1.8 2.1-2.8 4-2.8 1 0 1.8.2 2.5.6"></path>
          </svg>
        </span>
        Users
      </a>
      <a href="/superhost/dashboard?section=track-business#track-business" class="sidebar-link <%= activeSection === 'track-business' ? 'active' : '' %>">
        <span class="nav-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24">
            <path d="M3.5 17.5L9 12l3.2 3.2L20.5 7"></path>
            <path d="M14.5 7h6v6"></path>
          </svg>
        </span>
        Track Business
      </a>
      <a href="/superhost/dashboard?section=forex-events#forex-events" class="sidebar-link <%= activeSection === 'forex-events' ? 'active' : '' %>">
        <span class="nav-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24">
            <path d="M4 5.5h16"></path>
            <path d="M4 12h16"></path>
            <path d="M4 18.5h16"></path>
            <circle cx="8" cy="5.5" r="1.2"></circle>
            <circle cx="14" cy="12" r="1.2"></circle>
            <circle cx="10" cy="18.5" r="1.2"></circle>
          </svg>
        </span>
        Forex Events
      </a>
    </div>

    <div class="sidebar-group">
      <h2>Lab</h2>
      <a href="/superhost/dashboard?section=my-robots#my-robots" class="sidebar-link <%= activeSection === 'my-robots' ? 'active' : '' %>">
        <span class="nav-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24">
            <rect x="4.5" y="7.5" width="15" height="11" rx="2.2"></rect>
            <path d="M12 3.5v4"></path>
            <circle cx="9.2" cy="12.2" r="1"></circle>
            <circle cx="14.8" cy="12.2" r="1"></circle>
            <path d="M9 15.3h6"></path>
          </svg>
        </span>
        Manage EAs
      </a>
      <a href="/superhost/dashboard?section=portal-theme#portal-theme" class="sidebar-link <%= activeSection === 'portal-theme' ? 'active' : '' %>">
        <span class="nav-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24">
            <path d="M12 4.2a7.8 7.8 0 1 0 0 15.6h.3c1.6 0 2.3-1 2.3-2 0-.7-.3-1.3-.3-2 0-1.1.8-2 2.1-2h1.2a2.9 2.9 0 0 0 2.9-2.8A6.8 6.8 0 0 0 12 4.2z"></path>
            <circle cx="7.9" cy="11" r="1"></circle>
            <circle cx="11.2" cy="8.3" r="1"></circle>
            <circle cx="15.1" cy="9.2" r="1"></circle>
          </svg>
        </span>
        Portal Theme
      </a>
      <a href="/superhost/dashboard?section=my-profile#my-profile" class="sidebar-link <%= activeSection === 'my-profile' ? 'active' : '' %>">
        <span class="nav-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24">
            <circle cx="12" cy="8" r="3.2"></circle>
            <path d="M5 19c1.6-3 4-4.5 7-4.5s5.4 1.5 7 4.5"></path>
          </svg>
        </span>
        My Profile
      </a>
    </div>
  </aside>

  <div class="mentor-main">
    <section class="dashboard-overview <%= activeSection === 'overview' ? '' : 'section-hidden' %>" id="overview">
      <div class="overview-top-row">
        <p class="status-pill ok"><span>●</span>All systems running smoothly</p>
        <p class="status-pill"><span>📅</span>Today — <%= dashboardDateLabel %></p>
      </div>

      <article class="panel welcome-banner">
        <div class="welcome-icon" aria-hidden="true">🛡️</div>
        <div>
          <h2>Welcome back!</h2>
          <p class="welcome-sub">You are monitoring <strong><%= platformTotals.activeSubscribers %> active subscriptions</strong> across the portal.</p>
          <p class="mentor-id-pill">Superhost: <strong><%= currentUser.email %></strong></p>
        </div>
      </article>

      <div class="kpi-grid">
        <article class="kpi-card red">
          <h3>Total Licenses</h3>
          <p class="kpi-value"><%= platformTotals.totalGenerated %></p>
          <p>All generated keys</p>
        </article>
        <article class="kpi-card green">
          <h3>Active Subscriptions</h3>
          <p class="kpi-value"><%= platformTotals.activeSubscribers %></p>
          <p>Live paid clients</p>
        </article>
        <article class="kpi-card blue">
          <h3>Total Mentors</h3>
          <p class="kpi-value"><%= platformTotals.totalMentors %></p>
          <p>Mentors on portal</p>
        </article>
        <article class="kpi-card orange">
          <h3>Maximum Licenses</h3>
          <p class="kpi-value"><%= platformTotals.totalKeys %></p>
          <p>Combined mentor key limits</p>
        </article>
      </div>
    </section>

    <section class="panel-grid single <%= activeSection === 'users' ? '' : 'section-hidden' %>" id="users">
      <article class="panel">
        <h2>Users</h2>
        <p class="hint">Manage mentor signups, key limits, generated keys, and active paid subscribers.</p>

        <% if (!mentors.length) { %>
        <p class="hint">No mentors registered yet.</p>
        <% } else { %>
        <div class="users-list">
          <% mentors.forEach((mentor) => { %>
          <article class="user-card">
            <div class="user-card-head">
              <div>
                <h3><%= mentor.name %></h3>
                <p class="hint"><%= mentor.email %></p>
                <p class="hint">Mentor ID: <strong><%= mentor.mentorPortalId || '-' %></strong></p>
              </div>
              <div class="user-card-badges clean">
                <span class="pill <%= mentor.approved ? 'ok' : 'off' %>"><%= mentor.approved ? 'Approved' : 'Pending' %></span>
                <span class="pill <%= mentor.subscriptionActive ? 'ok' : 'off' %>"><%= mentor.subscriptionActive ? 'Sub Active' : 'Sub Inactive' %></span>
              </div>
            </div>

            <div class="user-metrics">
              <article>
                <span>Key Limit</span>
                <form action="/superhost/mentors/<%= mentor.id %>/license-limit" method="POST" class="inline-form row compact">
                  <input type="number" name="limit" min="0" value="<%= mentor.licenseKeyLimit %>" class="limit-input" required />
                  <button type="submit" class="button mini">Save</button>
                </form>
              </article>
              <article>
                <span>Keys Generated</span>
                <strong><%= mentor.totalKeys %></strong>
              </article>
              <article>
                <span>Active Subscribers</span>
                <strong><%= mentor.activeSubscribers %></strong>
              </article>
            </div>

            <div class="user-actions-row">
              <form action="/superhost/mentors/<%= mentor.id %>/approval" method="POST" class="inline-form">
                <input type="hidden" name="action" value="<%= mentor.approved ? 'revoke' : 'approve' %>" />
                <button type="submit" class="button mini <%= mentor.approved ? 'secondary' : '' %>">
                  <%= mentor.approved ? 'Revoke Approval' : 'Approve Mentor' %>
                </button>
              </form>

              <form action="/superhost/mentors/<%= mentor.id %>/subscription" method="POST" class="inline-form">
                <input type="hidden" name="action" value="<%= mentor.subscriptionActive ? 'deactivate' : 'activate' %>" />
                <button type="submit" class="button mini secondary">
                  <%= mentor.subscriptionActive ? 'Deactivate Sub' : 'Reactivate Sub' %>
                </button>
              </form>

              <a class="text-link" href="/superhost/mentors/<%= mentor.id %>">View Full Details</a>
            </div>
          </article>
          <% }) %>
        </div>
        <% } %>
      </article>
    </section>

    <section class="panel-grid single <%= activeSection === 'my-profile' ? '' : 'section-hidden' %>" id="my-profile">
      <article class="panel">
        <h2>My Profile (Superhost Test Lab)</h2>
        <p class="hint">Profile details are for portal use only.</p>

        <form action="/superhost/profile" method="POST" class="stack-form">
          <div class="row-fields">
            <label>
              Display Name
              <input type="text" name="name" value="<%= labAccount.name %>" required />
            </label>

            <label>
              Profile Headline
              <input type="text" name="profileHeadline" value="<%= labAccount.profileHeadline || '' %>" placeholder="Platform Superhost" />
            </label>
          </div>

          <label>
            Bio
            <textarea name="profileBio" rows="3"><%= labAccount.profileBio || '' %></textarea>
          </label>

          <div class="row-fields">
            <label>
              Phone
              <input type="text" name="profilePhone" value="<%= labAccount.profilePhone || '' %>" />
            </label>

            <label>
              Profile Image URL
              <input type="url" name="profileImageUrl" value="<%= labAccount.profileImageUrl || '' %>" placeholder="https://..." />
            </label>
          </div>

          <button type="submit" class="button">Save My Profile</button>
        </form>
      </article>
    </section>

    <section class="panel-grid single <%= activeSection === 'track-business' ? '' : 'section-hidden' %>" id="track-business">
      <article class="panel">
        <h2>Track My Business</h2>
        <p class="hint">Mentor-style metrics for superhost testing and benchmarking.</p>

        <form action="/superhost/business-settings" method="POST" class="stack-form">
          <div class="row-fields">
            <label>
              Robot Price (per key)
              <input type="number" name="robotPricePerKey" min="0" step="0.01" value="<%= labBusiness.robotPricePerKey %>" required />
            </label>

            <label>
              Monthly Target (keys)
              <input type="number" name="monthlyKeyTarget" min="0" step="1" value="<%= labBusiness.monthlyKeyTarget %>" required />
            </label>

            <label>
              Currency
              <select name="businessCurrency">
                <option value="ZAR" <%= labBusiness.businessCurrency === 'ZAR' ? 'selected' : '' %>>ZAR (R)</option>
                <option value="USD" <%= labBusiness.businessCurrency === 'USD' ? 'selected' : '' %>>USD ($)</option>
              </select>
            </label>
          </div>

          <button type="submit" class="button">Save Business Targets</button>
        </form>

        <div class="business-grid">
          <article class="business-card">
            <h3>Keys Sold (<%= labBusiness.monthLabel %>)</h3>
            <p class="business-value"><%= labBusiness.keysSoldThisMonth %></p>
          </article>

          <article class="business-card">
            <h3>Monthly Revenue</h3>
            <p class="business-value">R<%= Number(labBusiness.monthlyRevenue || 0).toFixed(2) %></p>
            <p class="hint">Subscription plans (ZAR)</p>
          </article>

          <article class="business-card">
            <h3>All-Time Revenue (Estimated)</h3>
            <p class="business-value">R<%= Number(labBusiness.estimatedTotalRevenue || 0).toFixed(2) %></p>
          </article>

          <article class="business-card">
            <h3>Projected Revenue (Your Price)</h3>
            <p class="business-value"><%= labBusiness.currencySymbol %><%= Number(labBusiness.projectedRevenueByMentorPrice || 0).toFixed(2) %></p>
          </article>

          <article class="business-card">
            <h3>Goal Revenue (At Target)</h3>
            <p class="business-value"><%= labBusiness.currencySymbol %><%= Number(labBusiness.goalRevenueAtTarget || 0).toFixed(2) %></p>
          </article>

          <article class="business-card">
            <h3>Target Remaining</h3>
            <p class="business-value"><%= labBusiness.targetRemaining || 0 %></p>
          </article>
        </div>
      </article>
    </section>

    <section class="stats-grid <%= activeSection === 'client-keys' ? '' : 'section-hidden' %>" id="client-keys">
      <article class="panel">
        <h2>Client Keys (Superhost Test Lab)</h2>
        <p><strong>Email:</strong> <%= labAccount.email %></p>
        <p><strong>Lab ID:</strong> <%= labAccount.mentorPortalId || 'SUPERHOST' %></p>
        <p><strong>Subscription Active:</strong> <%= labAccount.subscriptionActive ? 'Yes' : 'No' %></p>
        <p><strong>License Keys Used:</strong> <%= labActiveKeysUsed %> / <%= labAccount.licenseKeyLimit %></p>

        <form action="/superhost/license-keys/generate" method="POST" class="stack-form">
          <label>
            Client Email
            <input type="email" name="clientEmail" placeholder="client@example.com" required />
          </label>

          <label>
            Expert Advisor (Robot)
            <select name="robotId" required>
              <option value="">Select robot</option>
              <% labRobots.forEach((robot) => { %>
              <option value="<%= robot.id %>"><%= robot.name %></option>
              <% }) %>
            </select>
          </label>

          <label>
            License Key Duration
            <select name="durationCode" required>
              <option value="">Select duration</option>
              <% licenseDurationOptions.forEach((item) => { %>
              <option value="<%= item.code %>"><%= item.label %></option>
              <% }) %>
            </select>
          </label>
          <button type="submit" class="button" <%= labRobots.length ? '' : 'disabled' %>>
            Generate & Email Key
          </button>
        </form>

        <% if (!labRobots.length) { %>
        <p class="hint">Create at least one robot first before generating keys.</p>
        <% } %>

        <% if (!labLicenseKeys.length) { %>
        <p class="hint">No client keys generated yet.</p>
        <% } else { %>
        <ul class="list key-list">
          <% labLicenseKeys.forEach((item) => { %>
          <li class="key-entry">
            <div class="key-copy-row">
              <input type="text" class="key-copy-input" value="<%= item.key %>" readonly />
              <button type="button" class="button mini secondary copy-key-btn" data-copy-value="<%= item.key %>">Copy</button>
            </div>
            <p class="hint">
              Client: <strong><%= item.reservedClientEmail || 'N/A' %></strong> |
              EA: <strong><%= item.robotName || 'Not set' %></strong> |
              Duration: <strong><%= item.durationLabel || 'Not set' %></strong>
            </p>
            <% if (item.redeemedAt || item.status === 'redeemed') { %>
            <span class="pill ok">redeemed</span>
            <span class="hint">by <%= item.redeemedByClientEmail || 'client' %></span>
            <% } else if (item.reservedClientEmail) { %>
            <span class="pill">reserved</span>
            <span class="hint">for <%= item.reservedClientEmail %></span>
            <% } else { %>
            <span class="pill">available</span>
            <% } %>
          </li>
          <% }) %>
        </ul>
        <% } %>
      </article>
    </section>

    <section class="panel-grid single <%= activeSection === 'create-robot' ? '' : 'section-hidden' %>" id="create-robot">
      <article class="panel">
        <h2>Create Robot Profile (Superhost Test Lab)</h2>

        <form action="/superhost/robots" method="POST" class="stack-form">
          <label>
            Robot Name
            <input type="text" name="name" required />
          </label>

          <label>
            Description
            <textarea name="description" rows="3"></textarea>
          </label>

          <label>
            Category
            <input type="text" name="category" placeholder="Trading bot, assistant, support" />
          </label>

          <label>
            Robot Picture URL (Shown on client app)
            <input type="url" name="imageUrl" placeholder="https://..." />
          </label>

          <label>
            Symbols (comma or new line separated)
            <textarea name="allowedSymbols" rows="2" placeholder="XAUUSD, GBPUSD, .US30., BTCUSD"><%= defaultSymbolsText %></textarea>
          </label>

          <div class="row-fields">
            <label>
              Version
              <input type="text" name="version" placeholder="v1.0.0" />
            </label>

            <label>
              Status
              <select name="status">
                <option value="draft">Draft</option>
                <option value="active">Active</option>
                <option value="paused">Paused</option>
              </select>
            </label>
          </div>

          <h3>Key Stats</h3>
          <div class="row-fields">
            <label>
              Uptime (hours)
              <input type="number" step="1" name="uptimeHours" value="0" />
            </label>

            <label>
              Tasks Completed
              <input type="number" step="1" name="tasksCompleted" value="0" />
            </label>
          </div>

          <div class="row-fields">
            <label>
              Success Rate (%)
              <input type="number" step="0.01" name="successRate" value="0" />
            </label>

            <label>
              Last Sync
              <input type="text" name="lastSync" placeholder="2026-04-14T10:00:00Z" />
            </label>
          </div>

          <button type="submit" class="button">Create Robot</button>
        </form>
      </article>
    </section>

    <section class="panel-grid single <%= activeSection === 'my-robots' ? '' : 'section-hidden' %>" id="my-robots">
      <article class="panel">
        <h2>Manage EAs (Superhost Test Lab)</h2>
        <p class="hint">Create EAs, issue keys, and maintain symbols from one clean section.</p>
        <p><strong>License Keys Used:</strong> <%= labActiveKeysUsed %> / <%= labAccount.licenseKeyLimit %></p>

        <% if (!labAccount.subscriptionActive) { %>
        <p class="warning">Superhost lab subscription is inactive.</p>
        <% } %>

        <form action="/superhost/robots" method="POST" class="stack-form">
          <label>
            EA Name (Include Version)
            <input type="text" name="name" placeholder="ALGO NOVA EA v6" required />
          </label>

          <label class="confirm-check">
            <input type="checkbox" name="confirmAdmin" value="yes" required />
            <span>I confirm that I am an admin</span>
          </label>

          <label>
            Description
            <textarea name="description" rows="3"></textarea>
          </label>

          <label>
            Category
            <input type="text" name="category" placeholder="Trading bot, assistant, support" />
          </label>

          <label>
            Robot Picture URL (Shown on client app)
            <input type="url" name="imageUrl" placeholder="https://..." />
          </label>

          <label>
            Symbols (comma or new line separated)
            <textarea name="allowedSymbols" rows="2" placeholder="XAUUSD, GBPUSD, .US30., BTCUSD"><%= defaultSymbolsText %></textarea>
          </label>

          <div class="row-fields">
            <label>
              Version
              <input type="text" name="version" placeholder="v1.0.0" />
            </label>

            <label>
              Status
              <select name="status">
                <option value="draft">Draft</option>
                <option value="active">Active</option>
                <option value="paused">Paused</option>
              </select>
            </label>
          </div>

          <h3>Key Stats</h3>
          <div class="row-fields">
            <label>
              Uptime (hours)
              <input type="number" step="1" name="uptimeHours" value="0" />
            </label>

            <label>
              Tasks Completed
              <input type="number" step="1" name="tasksCompleted" value="0" />
            </label>
          </div>

          <div class="row-fields">
            <label>
              Success Rate (%)
              <input type="number" step="0.01" name="successRate" value="0" />
            </label>

            <label>
              Last Sync
              <input type="text" name="lastSync" placeholder="2026-04-14T10:00:00Z" />
            </label>
          </div>

          <button type="submit" class="button">Add EA</button>
        </form>

        <hr class="subtle-divider" />

        <h3>Manage Keys</h3>
        <form action="/superhost/license-keys/generate" method="POST" class="stack-form">
          <label>
            Client Email
            <input type="email" name="clientEmail" placeholder="client@example.com" required />
          </label>

          <label>
            Expert Advisor (Robot)
            <select name="robotId" required>
              <option value="">Select robot</option>
              <% labRobots.forEach((robot) => { %>
              <option value="<%= robot.id %>"><%= robot.name %></option>
              <% }) %>
            </select>
          </label>

          <label>
            License Key Duration
            <select name="durationCode" required>
              <option value="">Select duration</option>
              <% licenseDurationOptions.forEach((item) => { %>
              <option value="<%= item.code %>"><%= item.label %></option>
              <% }) %>
            </select>
          </label>
          <button type="submit" class="button" <%= labRobots.length ? '' : 'disabled' %>>
            Generate & Email Key
          </button>
        </form>

        <% if (!labLicenseKeys.length) { %>
        <p class="hint">No client keys generated yet.</p>
        <% } else { %>
        <ul class="list key-list">
          <% labLicenseKeys.forEach((item) => { %>
          <li class="key-entry">
            <div class="key-copy-row">
              <input type="text" class="key-copy-input" value="<%= item.key %>" readonly />
              <button type="button" class="button mini secondary copy-key-btn" data-copy-value="<%= item.key %>">Copy</button>
            </div>
            <p class="hint">
              Client: <strong><%= item.reservedClientEmail || 'N/A' %></strong> |
              EA: <strong><%= item.robotName || 'Not set' %></strong> |
              Duration: <strong><%= item.durationLabel || 'Not set' %></strong>
            </p>
            <% if (item.redeemedAt || item.status === 'redeemed') { %>
            <span class="pill ok">redeemed</span>
            <span class="hint">by <%= item.redeemedByClientEmail || 'client' %></span>
            <% } else if (item.reservedClientEmail) { %>
            <span class="pill">reserved</span>
            <span class="hint">for <%= item.reservedClientEmail %></span>
            <% } else { %>
            <span class="pill">available</span>
            <% } %>
          </li>
          <% }) %>
        </ul>
        <% } %>

        <hr class="subtle-divider" />

        <h3>Your Expert Advisors</h3>
        <% if (!labRobots.length) { %>
        <p class="hint">No robots created yet.</p>
        <% } else { %>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>Picture</th>
                <th>Name</th>
                <th>Category</th>
                <th>Status</th>
                <th>Version</th>
                <th>Key Stats</th>
                <th>Symbols</th>
                <th>Mobile Build</th>
                <th>Action</th>
              </tr>
            </thead>
            <tbody>
              <% labRobots.forEach((robot) => { %>
              <tr>
                <td>
                  <% if (robot.imageUrl) { %>
                  <img src="<%= robot.imageUrl %>" alt="<%= robot.name %> image" class="robot-thumb" />
                  <% } else { %>
                  <span class="hint">No image</span>
                  <% } %>
                </td>
                <td><%= robot.name %></td>
                <td><%= robot.category || '-' %></td>
                <td><span class="pill"><%= robot.status %></span></td>
                <td><%= robot.version %></td>
                <td>
                  Uptime: <%= robot.keyStats.uptimeHours %>h,
                  Tasks: <%= robot.keyStats.tasksCompleted %>,
                  Success: <%= robot.keyStats.successRate %>%
                </td>
                <td>
                  <form action="/superhost/robots/<%= robot.id %>/symbols" method="POST" class="table-inline-form">
                    <input type="text" name="allowedSymbols" value="<%= (robot.allowedSymbols || []).join(', ') %>" placeholder="XAUUSD, GBPUSD, .US30." class="table-inline-input" />
                    <button type="submit" class="button mini">Save</button>
                  </form>
                  <p class="hint"><%= (robot.allowedSymbols || []).length %> symbols</p>
                </td>
                <td>
                  <% if (robot.mobileBuild && robot.mobileBuild.status === 'ready') { %>
                  <span class="pill ok">Ready (Android + iOS)</span>
                  <% } else { %>
                  <span class="pill off">Not converted</span>
                  <% } %>
                </td>
                <td>
                  <form action="/superhost/robots/<%= robot.id %>/convert-mobile" method="POST">
                    <button type="submit" class="button mini">Convert to Mobile</button>
                  </form>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
        <% } %>
      </article>
    </section>

    <section class="panel-grid single <%= activeSection === 'forex-events' ? '' : 'section-hidden' %>" id="forex-events">
      <article class="panel">
        <h2>Forex Events</h2>
        <p class="hint">Showing upcoming events from <strong><%= forexEvents.fromLabel %></strong> to <strong><%= forexEvents.toLabel %></strong>. Past history is excluded automatically.</p>

        <% if (!forexEvents.items.length) { %>
        <p class="hint">No upcoming high-priority forex events are available right now.</p>
        <% } else { %>
        <div class="events-list">
          <% forexEvents.items.forEach((event) => { %>
          <article class="event-row">
            <div>
              <p class="event-title"><%= event.title %></p>
              <p class="hint"><%= event.dayLabel %> • <%= event.timeLabel %> (SAST)</p>
            </div>
            <div class="event-meta">
              <span class="pill"><%= event.country %></span>
              <span class="pill <%= String(event.impact || '').toLowerCase() === 'high' ? 'off' : 'ok' %>"><%= event.impact %></span>
            </div>
          </article>
          <% }) %>
        </div>
        <% } %>
      </article>
    </section>

    <section class="panel-grid single <%= activeSection === 'portal-theme' ? '' : 'section-hidden' %>" id="portal-theme">
      <article class="panel">
        <h2>Portal Theme</h2>
        <p class="hint">Theme controls moved lower so stats and operations show first.</p>

        <div class="cta-row">
          <form action="/superhost/theme" method="POST" class="inline-form">
            <input type="hidden" name="preset" value="dope_red" />
            <button type="submit" class="button secondary">Dope Red (Default)</button>
          </form>
          <form action="/superhost/theme" method="POST" class="inline-form">
            <input type="hidden" name="preset" value="neon_rose" />
            <button type="submit" class="button secondary">Neon Rose</button>
          </form>
          <form action="/superhost/theme" method="POST" class="inline-form">
            <input type="hidden" name="preset" value="acid_lime" />
            <button type="submit" class="button secondary">Acid Lime</button>
          </form>
          <form action="/superhost/theme" method="POST" class="inline-form">
            <input type="hidden" name="preset" value="ember_flux" />
            <button type="submit" class="button secondary">Ember Flux</button>
          </form>
          <form action="/superhost/theme" method="POST" class="inline-form">
            <input type="hidden" name="preset" value="cyber_sunset" />
            <button type="submit" class="button secondary">Cyber Sunset</button>
          </form>
        </div>

        <form action="/superhost/theme" method="POST" class="stack-form">
          <div class="row-fields">
            <label>Primary <input type="color" name="primary" value="<%= portalTheme.primary %>" /></label>
            <label>Secondary <input type="color" name="secondary" value="<%= portalTheme.secondary %>" /></label>
          </div>

          <div class="row-fields">
            <label>Tertiary <input type="color" name="tertiary" value="<%= portalTheme.tertiary %>" /></label>
            <label>Accent Pink <input type="color" name="accentPink" value="<%= portalTheme.accentPink %>" /></label>
          </div>

          <div class="row-fields">
            <label>Background Start <input type="color" name="bgStart" value="<%= portalTheme.bgStart %>" /></label>
            <label>Background End <input type="color" name="bgEnd" value="<%= portalTheme.bgEnd %>" /></label>
          </div>

          <div class="row-fields">
            <label>Glow <input type="color" name="glow" value="<%= portalTheme.glow %>" /></label>
          </div>

          <div class="cta-row">
            <button type="submit" class="button">Save Theme</button>
          </div>
        </form>
      </article>
    </section>
  </div>
</section>

<%- include('partials/bottom') %>
